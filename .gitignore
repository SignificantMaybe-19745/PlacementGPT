```gitignore
# =========================
# Dependencies
# =========================
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =========================
# Python
# =========================
.venv/
venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd

# =========================
# Interview dataset (very large)
# =========================
interview-data/
*.pdf

# =========================
# Next.js
# =========================
.next/
out/
build/

# =========================
# Coverage / Testing
# =========================
coverage/

# =========================
# Environment variables
# =========================
.env
.env.*
!.env.example

# =========================
# Prisma generated files
# =========================
generated/prisma/

# =========================
# Logs
# =========================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# OS / Editor
# =========================
.DS_Store
.vscode/settings.json

# =========================
# TypeScript
# =========================
*.tsbuildinfo
next-env.d.ts

# =========================
# Misc
# =========================
*.pem
.vercel/
```
